{
  "name": "React-FabricImage",
  "version": "5.2.0",
  "summary": "Image Component for Fabric for React Native.",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "13.4"
  },
  "source": {
    "git": "https://github.com/facebook/react-native.git",
    "tag": "v0.75.3"
  },
  "source_files": "packages/react-native/ReactCommon/react/renderer/components/image/**/*.{m,mm,cpp,h}",
  "exclude_files": "packages/react-native/ReactCommon/react/renderer/components/image/tests",
  "header_dir": "react/renderer/components/image",
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32",
  "pod_target_xcconfig": {
    "USE_HEADERMAP": "YES",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_TARGET_SRCROOT)/packages/react-native/ReactCommon\" \"$(PODS_ROOT)/RCT-Folly\" \"$(PODS_ROOT)/Headers/Private/Yoga\" \"$(PODS_ROOT)/DoubleConversion\" \"$(PODS_ROOT)/fast_float/include\" \"$(PODS_ROOT)/fmt/include\" \"$(PODS_ROOT)/Headers/Public/React-ImageManager\" \"$(PODS_ROOT)/Headers/Public/React-ImageManager/react/renderer/imagemanager\" \"$(PODS_ROOT)/Headers/Public/React-Fabric\" \"$(PODS_ROOT)/Headers/Public/React-Fabric/react/renderer\" \"$(PODS_ROOT)/Headers/Public/React-Fabric/react/renderer/imagemanager\" \"$(PODS_ROOT)/Headers/Public/React-Fabric/react/renderer/components/view/platform/cxx\" \"$(PODS_ROOT)/Headers/Public/React-rendererdebug\" \"$(PODS_ROOT)/React-Fabric/packages/react-native/ReactCommon\" \"$(PODS_ROOT)/React-ImageManager/packages/react-native/ReactCommon\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-ImageManager/React_ImageManager.framework/Headers\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-ImageManager/React_ImageManager.framework/Headers/react/renderer/imagemanager\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-Fabric/React_Fabric.framework/Headers\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-Fabric/React_Fabric.framework/Headers/react/renderer/imagemanager\""
  },
  "dependencies": {
    "RCT-Folly/Fabric": [
      "5.2.0"
    ],
    "React-jsiexecutor": [
      "5.2.0"
    ],
    "RCTRequired": [
      "5.2.0"
    ],
    "RCTTypeSafety": [
      "5.2.0"
    ],
    "React-jsi": [
      "5.2.0"
    ],
    "React-logger": [
      "5.2.0"
    ],
    "glog": [
      "5.2.0"
    ],
    "DoubleConversion": [
      "5.2.0"
    ],
    "fmt": [
      "5.2.0"
    ],
    "React-ImageManager": [
      "5.2.0"
    ],
    "React-utils": [
      "5.2.0"
    ],
    "Yoga": [
      "5.2.0"
    ],
    "ReactCommon": [
      "5.2.0"
    ],
    "React-graphics": [
      "5.2.0"
    ],
    "React-Fabric": [
      "5.2.0"
    ],
    "React-rendererdebug": [
      "5.2.0"
    ],
    "React-jsc": [
      "5.2.0"
    ]
  }
}