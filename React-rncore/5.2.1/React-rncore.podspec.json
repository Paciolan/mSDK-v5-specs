{
  "name": "React-rncore",
  "version": "5.2.1",
  "summary": "Fabric for React Native.",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "13.4"
  },
  "source": {
    "git": "https://github.com/Paciolan/mSDK-v5-pod.git",
    "tag": "5.2.1"
  },
  "pod_target_xcconfig": {
    "USE_HEADERMAP": "YES",
    "HEADER_SEARCH_PATHS": "\"$(PODS_TARGET_SRCROOT)/PaciolanSDK/Assets\" \"${PODS_CONFIGURATION_BUILD_DIR}/ReactCommon/ReactCommon.framework/Headers/react/nativemodule/core\" \"$(PODS_ROOT)/Headers/Private/React-Fabric\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-Fabric/React_Fabric.framework/Headers\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-Fabric/React_Fabric.framework/Headers/react/renderer/components/view/platform/cxx\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-FabricImage/React_FabricImage.framework/Headers\" \"${PODS_CONFIGURATION_BUILD_DIR}/React-Fabric/React_Fabric.framework/Headers/react/renderer/components/view/platform/cxx\"  \"$(PODS_ROOT)/RCT-Folly\" \"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/DoubleConversion\" \"$(PODS_ROOT)/fmt/include\" \"$(PODS_ROOT)/Headers/Public/React-rendererdebug\" \"$(PODS_ROOT)/Headers/Private/React-rendererdebug\" \"$(PODS_ROOT)/Headers/Public/React-debug\" \"$(PODS_ROOT)/Headers/Private/React-debug\" \"$(PODS_ROOT)/Headers/Public/React-graphics\" \"$(PODS_ROOT)/Headers/Private/React-graphics\" \"$(PODS_ROOT)/Headers/Public/React-utils\" \"$(PODS_ROOT)/Headers/Private/React-utils\" \"$(PODS_ROOT)/Headers/Public/React-jsi\" \"$(PODS_ROOT)/Headers/Private/React-jsi\" \"$(PODS_ROOT)/Headers/Public/React-featureflags\" \"$(PODS_ROOT)/Headers/Private/React-featureflags\" \"$(PODS_ROOT)/Headers/Public/React-rendererconsistency\" \"$(PODS_ROOT)/Headers/Private/React-rendererconsistency\" \"$(PODS_ROOT)/Headers/Public/React-runtimescheduler\" \"$(PODS_ROOT)/Headers/Private/React-runtimescheduler\" \"$(PODS_ROOT)/Headers/Public/React-performancetimeline\" \"$(PODS_ROOT)/Headers/Private/React-performancetimeline\" \"$(PODS_ROOT)/Headers/Public/React-logger\" \"$(PODS_ROOT)/Headers/Private/React-logger\" \"$(PODS_ROOT)/Headers/Public/React-callinvoker\" \"$(PODS_ROOT)/Headers/Private/React-callinvoker\" \"$(PODS_ROOT)/Headers/Public/glog\" \"$(PODS_ROOT)/Headers/Private/glog\" \"$(PODS_ROOT)/Headers/Public/Yoga\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20"
  },
  "script_phases": [
    {
      "name": "Copy files",
      "script": "PUBLIC_DIR=\"${PODS_ROOT}/Headers/Public/React-FabricComponents/react/renderer/components/rncore\"\nPRIVATE_DIR=\"${PODS_ROOT}/Headers/Private/React-FabricComponents/react/renderer/components/rncore\"\nCOMPONENTS_DIR=\"${PODS_ROOT}/React-FabricComponents/packages/react-native/ReactCommon/react/renderer/components\"\nSRC_DIR=\"${PODS_TARGET_SRCROOT}/PaciolanSDK/Assets/react/renderer/components/rncore\"\nmkdir -p \"$PUBLIC_DIR\" \"$PRIVATE_DIR\" \"$COMPONENTS_DIR\"\nchmod -R u+w \"$PUBLIC_DIR\" \"$PRIVATE_DIR\" \"$COMPONENTS_DIR/rncore\" 2>/dev/null || true\nfind \"$SRC_DIR\" -name \"*.h\" -print\nfor header in \"$SRC_DIR\"/*.h; do\n  [ -e \"$header\" ] || continue\n  cp -f \"$header\" \"$PUBLIC_DIR/\"\n  cp -f \"$header\" \"$PRIVATE_DIR/\"\ndone\nrm -rf \"$COMPONENTS_DIR/rncore\"\ncp -R \"$SRC_DIR\" \"$COMPONENTS_DIR\"",
      "execution_position": "before_compile"
    }
  ],
  "source_files": "PaciolanSDK/Assets/react/renderer/components/rncore/**/*.{h,mm,cpp}",
  "public_header_files": "PaciolanSDK/Assets/react/renderer/components/rncore/**/*.h",
  "header_dir": "react/renderer/components/rncore",
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32"
}
