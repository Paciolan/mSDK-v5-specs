      "5.5.0"
    ],
    "React-runtimescheduler": [
      "5.5.0"
    ],
    "React-utils": [
      "5.5.0"
    ],
    "React-jsi": [
      "5.5.0"
    ],
    "React-Core/Default": [
      "5.5.0"
    ],
    "React-CoreModules": [
      "5.5.0"
    ],
    "React-NativeModulesApple": [
      "5.5.0"
    ],
    "React-RCTFabric": [
      "5.5.0"
    ],
    "React-RuntimeCore": [
      "5.5.0"
    ],
    "React-Mapbuffer": [],
    "React-jserrorhandler": [
      "5.5.0"
    ],
    "React-jsinspector": [
      "5.5.0"
    ],
    "React-featureflags": [],
